# Variables públicas (se inyectan en el bundle, no pongas secretos service_role aquí)

# URL del proyecto Supabase
EXPO_PUBLIC_SUPABASE_URL=

# Anon key (público, seguro de exponer)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Base URL del backend Go (Fly.io)
EXPO_PUBLIC_API_URL=http://localhost:8080

# Modo mocks: si es "true", la app usa datos locales sin conectar a Supabase ni al backend
EXPO_PUBLIC_USE_MOCKS=true
