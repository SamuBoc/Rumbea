# Puerto del servidor (Fly.io setea PORT automáticamente en producción)
PORT=8080

# Connection string de Supabase Postgres (pooler recomendado para serverless)
# Formato: postgresql://postgres.<project-ref>:<password>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# JWT secret de Supabase (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=

# URL del proyecto Supabase (para logs/ref, no estrictamente usado por el backend)
SUPABASE_URL=

# Entorno: development | production
ENV=development

# Orígenes permitidos para CORS (coma-separados). Deja "*" en dev.
CORS_ALLOWED_ORIGINS=*
